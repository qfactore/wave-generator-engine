{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wge.local/schemas/run-request-v1.json",
  "title": "WGE Non-Executable Run Request",
  "type": "object",
  "required": ["schema_version", "source_profile_id", "delivery_preset_id", "selected_session_ids", "requested_duration_seconds", "requested_export_target"],
  "properties": {
    "schema_version": {"const": "wge.run_request.v1"},
    "source_profile_id": {"type": "string"},
    "delivery_preset_id": {"type": "string"},
    "selected_session_ids": {"type": "array", "minItems": 1, "maxItems": 7, "items": {"type": "integer"}},
    "requested_duration_seconds": {"type": "integer", "minimum": 1},
    "focus_role_override": {"type": ["object", "null"]},
    "playback_default_override": {"type": ["number", "null"]},
    "requested_export_target": {"enum": ["diagnostic_wav", "playback_json", "analysis_report", "assembled_stereo_wav_pack"]},
    "random_seed": {"type": ["integer", "null"]},
    "motif_time_scale_ratio": {"type": ["number", "null"]},
    "carrier_frequency_hz": {"type": ["number", "null"]},
    "notes": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": false
}
