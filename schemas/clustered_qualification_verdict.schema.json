{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "verdict",
    "wge5c_clustered_render_authorized",
    "content_invariance",
    "gap_semantics",
    "meso_comparisons",
    "existing_source_qualification",
    "holdout_qualification",
    "determinism",
    "core_plans_unchanged",
    "audio_created",
    "content_hash"
  ],
  "properties": {
    "schema_version": {"const": "wge.clustered_qualification_verdict.v1"},
    "verdict": {
      "enum": [
        "qualified_for_clustered_diagnostic_render",
        "qualified_with_documented_caveats",
        "not_qualified_for_clustered_render"
      ]
    },
    "wge5c_clustered_render_authorized": {"type": "boolean"},
    "core_plans_unchanged": {"const": true},
    "audio_created": {"const": false},
    "content_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
