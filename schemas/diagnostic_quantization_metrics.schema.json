{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema_version", "maximum_allowed_error", "branches", "global_maximum_quantization_error", "global_mean_absolute_quantization_error", "content_hash"],
  "properties": {
    "schema_version": {"const": "wge.diagnostic_quantization_metrics.v1"},
    "maximum_allowed_error": {"const": 0.0000152587890625},
    "branches": {"type": "array", "minItems": 4, "maxItems": 4},
    "global_maximum_quantization_error": {"type": "number", "maximum": 0.0000152587890625},
    "content_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
